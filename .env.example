# Database (Neon PostgreSQL via Vercel integration)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Password for the matchmaker dashboard at /dashboard
MATCHMAKER_PASSWORD="your-password-here"

# OpenAI API key (optional — used for industry enrichment from company URLs)
OPENAI_API_KEY=""

# Time slots available for matching (comma-separated)
EVENT_SLOTS="10:00-11:00,11:00-12:00,12:00-13:00,13:00-14:00,14:00-15:00,15:00-16:00,16:00-17:00,17:00-18:00"
